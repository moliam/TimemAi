#!/usr/bin/env expect
#
# Real PTY smoke for Timem's interactive input layer.
#
# This intentionally drives the compiled shell through a pseudo terminal instead
# of calling pure functions. It uses a dummy API key and only exercises local
# commands / cancelled input, so it should not call an LLM provider.

set timeout 10

set repo_root [file normalize [file join [file dirname [info script]] ".."]]
set binary [file join $repo_root "target" "release" "timem-native-rs"]

if {![file executable $binary]} {
    puts stderr "missing executable: $binary"
    puts stderr "run: cargo build -p timem_shell --release"
    exit 1
}

proc wait_prompt {} {
    global spawn_id
    while {1} {
        expect {
            -re "\033\\\[6n" {
                send "\033\[24;1R"
                exp_continue
            }
            -re "❯❯" {
                return
            }
            timeout {
                error "timeout waiting for Timem prompt"
            }
            eof {
                error "unexpected EOF waiting for Timem prompt"
            }
        }
    }
}

proc wait_exit {} {
    global spawn_id
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        eof {
            return
        }
        timeout {
            error "timeout waiting for Timem exit"
        }
    }
}

proc spawn_timem {} {
    global binary spawn_id
    spawn env \
        TIMEM_API_KEY=dummy \
        TIMEM_GATEWAY_PROVIDER=aliyun \
        TIMEM_MODEL=qwen-plus \
        $binary --space .tty_smoke_mem
    wait_prompt
}

proc exit_timem {} {
    send "/exit\r"
    wait_exit
}

proc assert_no_model_call {scenario output} {
    if {[regexp {思考中|qwen-plus: ▲1|chj:qwen-plus|aliyun:qwen-plus} $output]} {
        error "$scenario unexpectedly triggered a model call"
    }
}

proc run_prof_smoke {} {
    spawn_timem
    send "/prof\r"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "Token" {}
        timeout {
            error "timeout waiting for /prof output"
        }
        eof {
            error "unexpected EOF waiting for /prof output"
        }
    }
    wait_prompt
    exit_timem
}

proc run_multiline_paste_cancel_smoke {} {
    spawn_timem
    after 200
    send "\033\[200~第一行中文；abc\n第二行 English；123\n第三行 │ TIMEM_MODEL │ qwen-plus │\033\[201~"
    after 300
    send "\003"

    set output ""
    expect {
        -re "\033\\\[6n" {
            append output $expect_out(buffer)
            send "\033\[24;1R"
            exp_continue
        }
        -re "❯❯" {
            append output $expect_out(buffer)
        }
        timeout {
            error "timeout waiting after multiline paste cancel"
        }
        eof {
            error "unexpected EOF after multiline paste cancel"
        }
    }
    assert_no_model_call "multiline paste cancel" $output
    exit_timem
}

proc run_shift_enter_cancel_smoke {} {
    spawn_timem
    after 200
    send "第一行中文；abc"
    send "\033\[13;2u"
    send "第二行 English；123"
    after 300
    send "\003"

    set output ""
    expect {
        -re "\033\\\[6n" {
            append output $expect_out(buffer)
            send "\033\[24;1R"
            exp_continue
        }
        -re "❯❯" {
            append output $expect_out(buffer)
        }
        timeout {
            error "timeout waiting after Shift+Enter cancel"
        }
        eof {
            error "unexpected EOF after Shift+Enter cancel"
        }
    }
    assert_no_model_call "Shift+Enter cancel" $output
    exit_timem
}

proc run_wrapped_edit_cancel_smoke {} {
    spawn_timem
    after 200
    send "阿萨德；房间啊实打实的发；按时 阿斯蒂芬；阿萨德发生；理发店啊；水电费啊；乐山大佛；拉的放假啊；收到了减肥假啊；收到了减肥假啊；收到了减肥"
    after 200
    send "\177\177\177"
    after 100
    send "\033\[D\033\[D\033\[D\033\[D\033\[D"
    after 300
    send "\003"

    set output ""
    expect {
        -re "\033\\\[6n" {
            append output $expect_out(buffer)
            send "\033\[24;1R"
            exp_continue
        }
        -re "❯❯" {
            append output $expect_out(buffer)
        }
        timeout {
            error "timeout waiting after wrapped edit cancel"
        }
        eof {
            error "unexpected EOF after wrapped edit cancel"
        }
    }
    assert_no_model_call "wrapped edit cancel" $output
    exit_timem
}

run_prof_smoke
run_multiline_paste_cancel_smoke
run_shift_enter_cancel_smoke
run_wrapped_edit_cancel_smoke

puts "real_tty_smoke: ok"
