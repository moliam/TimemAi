#!/usr/bin/env expect
#
# Real PTY smoke for Timem's interactive input layer.
#
# This intentionally drives the compiled shell through a pseudo terminal instead
# of calling pure functions. It uses a dummy API key and only exercises local
# commands / cancelled input, so it should not call an LLM provider.

set timeout 10

set repo_root [file normalize [file join [file dirname [info script]] ".."]]
set binary [file join $repo_root "target" "release" "timem-native-rs"]
set data_dir [file join "/private/tmp" "timem_tty_smoke_[pid]"]

if {![file executable $binary]} {
    puts stderr "missing executable: $binary"
    puts stderr "run: cargo build -p timem_shell --release"
    exit 1
}

proc wait_prompt {} {
    global spawn_id
    while {1} {
        expect {
            -re "\033\\\[6n" {
                send "\033\[24;1R"
                exp_continue
            }
            -re "❯❯" {
                return
            }
            timeout {
                error "timeout waiting for Timem prompt"
            }
            eof {
                error "unexpected EOF waiting for Timem prompt"
            }
        }
    }
}

proc wait_exit {} {
    global spawn_id
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        eof {
            return
        }
        timeout {
            error "timeout waiting for Timem exit"
        }
    }
}

proc spawn_timem {} {
    global binary data_dir spawn_id
    spawn env \
        TIMEM_API_KEY=dummy \
        TIMEM_GATEWAY_PROVIDER=aliyun \
        TIMEM_MODEL=qwen-plus \
        TIMEM_DATA_DIR=$data_dir \
        $binary --space .tty_smoke_mem
    expect {
        -re "\033\\\[\\?2004h" {}
        timeout {
            error "timeout waiting for bracketed paste mode enable"
        }
        eof {
            error "unexpected EOF waiting for bracketed paste mode enable"
        }
    }
    wait_prompt
}

proc exit_timem {} {
    send "/exit\r"
    wait_exit
}

proc assert_no_model_call {scenario output} {
    if {[regexp {思考中|qwen-plus: ▲1|aliyun:qwen-plus|模型调用失败} $output]} {
        error "$scenario unexpectedly triggered a model call"
    }
}

proc assert_contains {scenario output needle} {
    if {[string first $needle $output] < 0} {
        error "$scenario expected output to contain: $needle"
    }
}

proc assert_cancelled {scenario output} {
    assert_contains $scenario $output "已取消当前输入"
}

proc wait_cancelled {scenario} {
    set output ""
    expect {
        -re "\033\\\[6n" {
            append output $expect_out(buffer)
            send "\033\[24;1R"
            if {[string first "已取消当前输入" $output] >= 0} {
                return $output
            }
            exp_continue
        }
        -re "已取消当前输入" {
            append output $expect_out(buffer)
        }
        -re "❯❯" {
            append output $expect_out(buffer)
            if {[string first "已取消当前输入" $output] >= 0} {
                return $output
            }
            exp_continue
        }
        timeout {
            error "timeout waiting for cancellation in $scenario"
        }
        eof {
            error "unexpected EOF waiting for cancellation in $scenario"
        }
    }
    return $output
}

proc assert_not_repeated_too_much {scenario output needle limit} {
    set count 0
    set start 0
    while {1} {
        set index [string first $needle $output $start]
        if {$index < 0} {
            break
        }
        incr count
        set start [expr {$index + [string length $needle]}]
    }
    if {$count > $limit} {
        error "$scenario repeated '$needle' $count times, expected <= $limit"
    }
}

proc run_prof_smoke {} {
    spawn_timem
    send "/prof\r"
    set output ""
    expect {
        -re "\033\\\[6n" {
            append output $expect_out(buffer)
            send "\033\[24;1R"
            if {[string first "Token" $output] >= 0} {
                # The device-status query can arrive in the same buffer as the
                # /prof output; stop waiting for Token but still exit normally.
            }
            if {[string first "Token" $output] < 0} {
                exp_continue
            }
        }
        -re "Token" {
            append output $expect_out(buffer)
        }
        timeout {
            error "timeout waiting for /prof output"
        }
        eof {
            error "unexpected EOF waiting for /prof output"
        }
    }
    wait_prompt
    exit_timem
}

proc run_multiline_paste_cancel_smoke {} {
    spawn_timem
    after 200
    send "\033\[200~第一行中文；abc\n第二行 English；123\n第三行 │ TIMEM_MODEL │ qwen-plus │\033\[201~"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "pasted 3 lines" {}
        timeout {
            error "timeout waiting for multiline paste placeholder"
        }
        eof {
            error "unexpected EOF waiting for multiline paste placeholder"
        }
    }
    after 300
    send "\003"
    set output [wait_cancelled "multiline paste cancel"]
    assert_no_model_call "multiline paste cancel" $output
    assert_cancelled "multiline paste cancel" $output
    exit_timem
}

proc run_edited_paste_recovery_ctrl_c_smoke {} {
    spawn_timem
    after 200
    send "\033\[200~第一行中文；abc\n第二行 English；123\n第三行 │ TIMEM_MODEL │ qwen-plus │\033\[201~"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "pasted 3 lines" {}
        timeout {
            error "timeout waiting for edited paste placeholder"
        }
        eof {
            error "unexpected EOF waiting for edited paste placeholder"
        }
    }
    after 300
    send "\033\[D"
    send "x"
    send "\r"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "可能被误编辑" {}
        timeout {
            error "timeout waiting for paste recovery confirmation"
        }
        eof {
            error "unexpected EOF waiting for paste recovery confirmation"
        }
    }
    send "\003"
    set output [wait_cancelled "edited paste recovery ctrl-c"]
    assert_no_model_call "edited paste recovery ctrl-c" $output
    assert_cancelled "edited paste recovery ctrl-c" $output
    exit_timem
}

proc run_edited_paste_recovery_esc_smoke {} {
    spawn_timem
    after 200
    send "\033\[200~第一行中文；abc\n第二行 English；123\n第三行 │ TIMEM_MODEL │ qwen-plus │\033\[201~"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "pasted 3 lines" {}
        timeout {
            error "timeout waiting for edited paste placeholder before Esc"
        }
        eof {
            error "unexpected EOF waiting for edited paste placeholder before Esc"
        }
    }
    after 300
    send "\033\[D"
    send "x"
    send "\r"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "可能被误编辑" {}
        timeout {
            error "timeout waiting for paste recovery confirmation before Esc"
        }
        eof {
            error "unexpected EOF waiting for paste recovery confirmation before Esc"
        }
    }
    send "\033"
    set output [wait_cancelled "edited paste recovery esc"]
    assert_no_model_call "edited paste recovery esc" $output
    assert_cancelled "edited paste recovery esc" $output
    exit_timem
}

proc run_edited_paste_recovery_return_to_edit_smoke {} {
    spawn_timem
    after 200
    send "\033\[200~第一行中文；abc\n第二行 English；123\n第三行 │ TIMEM_MODEL │ qwen-plus │\033\[201~"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "pasted 3 lines" {}
        timeout {
            error "timeout waiting for return-edit paste placeholder"
        }
        eof {
            error "unexpected EOF waiting for return-edit paste placeholder"
        }
    }
    after 300
    send "\033\[D"
    send "x"
    send "\r"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "返回编辑" {}
        timeout {
            error "timeout waiting for paste recovery return-edit option"
        }
        eof {
            error "unexpected EOF waiting for paste recovery return-edit option"
        }
    }
    send "\r"
    set return_edit_output ""
    expect {
        -re "\033\\\[6n" {
            append return_edit_output $expect_out(buffer)
            send "\033\[24;1R"
            exp_continue
        }
        -re "pasted 3 lines.*x" {}
        timeout {
            error "timeout waiting for edited paste text to return to input"
        }
        eof {
            error "unexpected EOF waiting for edited paste text to return to input"
        }
    }
    append return_edit_output $expect_out(buffer)
    if {![regexp {\033\[([0-9]+)F\033\[J} $return_edit_output _ clear_lines]} {
        error "return-edit did not clear the paste recovery note before restoring input"
    }
    if {$clear_lines <= 8} {
        error "return-edit cleared only $clear_lines lines; expected note plus original input line"
    }
    send "\003"
    set output [wait_cancelled "edited paste recovery return-edit"]
    assert_no_model_call "edited paste recovery return-edit" $output
    assert_cancelled "edited paste recovery return-edit" $output
    exit_timem
}

proc run_shift_enter_cancel_smoke {} {
    spawn_timem
    after 200
    send "第一行中文；abc"
    send "\033\[13;2u"
    send "第二行 English；123"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "第二行 English；123" {}
        timeout {
            error "timeout waiting for Shift+Enter second line"
        }
        eof {
            error "unexpected EOF waiting for Shift+Enter second line"
        }
    }
    after 300
    send "\003"
    set output [wait_cancelled "Shift+Enter cancel"]
    assert_no_model_call "Shift+Enter cancel" $output
    assert_cancelled "Shift+Enter cancel" $output
    exit_timem
}

proc run_wrapped_edit_cancel_smoke {} {
    spawn_timem
    after 200
    send "阿萨德；房间啊实打实的发；按时 阿斯蒂芬；阿萨德发生；理发店啊；水电费啊；乐山大佛；拉的放假啊；收到了减肥假啊；收到了减肥假啊；收到了减肥"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "收到了减肥" {}
        timeout {
            error "timeout waiting for wrapped input render"
        }
        eof {
            error "unexpected EOF waiting for wrapped input render"
        }
    }
    after 200
    send "\177\177\177"
    after 100
    send "\033\[D\033\[D\033\[D\033\[D\033\[D"
    after 300
    send "\003"
    set output [wait_cancelled "wrapped edit cancel"]
    assert_no_model_call "wrapped edit cancel" $output
    assert_cancelled "wrapped edit cancel" $output
    assert_not_repeated_too_much "wrapped edit cancel" $output "收到了减肥" 6
    exit_timem
}

proc run_config_value_cancel_smoke {} {
    spawn_timem
    send "/config\r"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "选择要修改的配置" {}
        timeout {
            error "timeout waiting for /config menu"
        }
        eof {
            error "unexpected EOF waiting for /config menu"
        }
    }
    send "\r"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "请输入新值" {}
        timeout {
            error "timeout waiting for /config value prompt"
        }
        eof {
            error "unexpected EOF waiting for /config value prompt"
        }
    }
    send "\003"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "已取消配置修改" {}
        timeout {
            error "timeout waiting for Ctrl+C config cancellation"
        }
        eof {
            error "Ctrl+C exited Timem while editing config value"
        }
    }
    wait_prompt

    send "/config\r"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "选择要修改的配置" {}
        timeout {
            error "timeout waiting for second /config menu"
        }
        eof {
            error "unexpected EOF waiting for second /config menu"
        }
    }
    send "\r"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "请输入新值" {}
        timeout {
            error "timeout waiting for second /config value prompt"
        }
        eof {
            error "unexpected EOF waiting for second /config value prompt"
        }
    }
    send "\033"
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "已取消配置修改" {}
        timeout {
            error "timeout waiting for Esc config cancellation"
        }
        eof {
            error "Esc exited Timem while editing config value"
        }
    }
    wait_prompt
    exit_timem
}

