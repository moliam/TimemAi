#!/usr/bin/env expect
#
# Real PTY stress for active rendering while the core is doing model/action work.
# It drives the release binary through a pseudo terminal and a local fake
# OpenAI-compatible provider. The scenario covers:
# - repeated Thought / Action redraws while waiting for the model
# - user supplement during a running model request
# - long progress and long command action rendering
# - local action execution and a follow-up model round

set timeout 180
log_user 0

set repo_root [file normalize [file join [file dirname [info script]] ".."]]
set binary [file join $repo_root "target" "release" "timem-native-rs"]
set provider_script [file join $repo_root "scripts" "fake_openai_provider.py"]
set data_dir [file join "/private/tmp" "timem_tty_stress_[pid]"]
set port 0

if {![file executable $binary]} {
    puts stderr "missing executable: $binary"
    puts stderr "run: cargo build -p timem_shell --release"
    exit 1
}

proc wait_prompt {} {
    while {1} {
        expect {
            -re "\033\\\[6n" {
                send "\033\[24;1R"
                exp_continue
            }
            -re "❯❯" {
                return
            }
            timeout {
                error "timeout waiting for Timem prompt"
            }
            eof {
                error "unexpected EOF waiting for Timem prompt"
            }
        }
    }
}

proc wait_for_thinking_panel {} {
    expect {
        -re "\033\\\[6n" {
            send "\033\[24;1R"
            exp_continue
        }
        -re "Thought / Action" {
            return
        }
        timeout {
            error "timeout waiting for Thought / Action panel"
        }
        eof {
            error "unexpected EOF waiting for Thought / Action panel"
        }
    }
}

spawn -noecho python3 -u $provider_script --port $port --delay 1.8
set provider_spawn_id $spawn_id
expect {
    -re {fake_provider_ready:([0-9]+)} {
        set port $expect_out(1,string)
    }
    timeout {
        error "timeout waiting for fake provider"
    }
    eof {
        error "fake provider exited before ready"
    }
}

spawn env \
    TIMEM_API_KEY=dummy \
    TIMEM_GATEWAY_PROVIDER=local \
    TIMEM_API_PROTOCOL=openai-compatible \
    TIMEM_BASE_URL=http://127.0.0.1:$port/v1 \
    TIMEM_MODEL=fake-stress-model \
    TIMEM_BASH_APPROVAL=approve \
    TIMEM_DATA_DIR=$data_dir \
    $binary --space .tty_stress_smoke
expect {
    -re "\033\\\[\\?2004h" {}
    timeout {
        error "timeout waiting for bracketed paste mode enable"
    }
    eof {
        error "unexpected EOF waiting for bracketed paste mode enable"
    }
}
wait_prompt
send "TTY_STRESS：请执行一次终端渲染压力测试，最后只回答 STRESS_OK。\r"
wait_for_thinking_panel
after 400
send "补充：保持最终答案为 STRESS_OK，并继续执行本地检查。\r"

set output ""
set saw_action_render 0
expect {
    -re "\033\\\[6n" {
        append output $expect_out(buffer)
        send "\033\[24;1R"
        exp_continue
    }
    -re "思考中\\.\\.\\. x2" {
        error "thinking transient should not duplicate as x2 during stress"
    }
    -re "模型调用失败" {
        error "stress scenario should not fail model call"
    }
    -re "STRESS_ACTION_DONE" {
        set saw_action_render 1
        append output $expect_out(buffer)
        exp_continue
    }
    -re "STRESS_OK" {
        append output $expect_out(buffer)
        wait_prompt
        if {!$saw_action_render && [string first "STRESS_ACTION_DONE" $output] < 0} {
            error "stress scenario did not render command action"
        }
        send "/exit\r"
        expect {
            -re "\033\\\[6n" {
                send "\033\[24;1R"
                exp_continue
            }
            eof {}
            timeout {}
        }
        set spawn_id $provider_spawn_id
        catch {close}
        catch {wait}
        puts "real_tty_stress: ok"
        exit 0
    }
    timeout {
        # Strip ANSI escape sequences and check if STRESS_OK was present
        set stripped $output
        regsub -all {\[[0-9;]*[a-zA-Z]} $stripped "" stripped
        regsub -all {\[[0-9;]*m} $stripped "" stripped
        regsub -all {\[[\?]?[0-9;]*[hlsr]} $stripped "" stripped
        if {[string first "STRESS_OK" $stripped] >= 0} {
            wait_prompt
            if {!$saw_action_render && [string first "STRESS_ACTION_DONE" $output] < 0} {
                error "stress scenario did not render command action"
            }
            send "/exit"
            catch {close}
            puts "real_tty_stress: ok (after escape stripping)"
            exit 0
        }
        error "timeout waiting for stress answer; captured output=$output"
    }
    eof {
        error "unexpected EOF waiting for stress answer"
    }
}
